generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  FOLLOW_UP
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  leadsOwned   Lead[]   @relation("LeadOwner")
  accountsOwned Account[] @relation("AccountOwner")
  contactsOwned Contact[] @relation("ContactOwner")
  opportunitiesOwned Opportunity[] @relation("OpportunityOwner")
  activitiesOwned Activity[] @relation("ActivityOwner")
  tasksOwned Task[] @relation("TaskOwner")
  notesAuthored Note[] @relation("NoteAuthor")
  noteCommentsAuthored NoteComment[] @relation("NoteCommentAuthor")
  opportunityStageHistories OpportunityStageHistory[] @relation("OpportunityStageActor")
  auditLogs    AuditLog[] @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  module          String
  action          String
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Lead {
  id          String     @id @default(uuid())
  fullName    String
  companyName String?
  email       String?
  phone       String?
  source      String?
  industry    String?
  region      String?
  status      LeadStatus @default(NEW)
  score       Int?
  notes       String?
  ownerId     String
  owner       User       @relation("LeadOwner", fields: [ownerId], references: [id])
  activities  Activity[] @relation("LeadActivities")
  tasks       Task[]     @relation("LeadTasks")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Account {
  id                 String       @id @default(uuid())
  companyName         String
  type               String?
  segment            String?
  industry           String?
  address            String?
  taxId              String?
  status             String       @default("ACTIVE")
  annualValueEstimate Int?
  notes              String?
  ownerId            String
  owner              User         @relation("AccountOwner", fields: [ownerId], references: [id])
  contacts           Contact[]
  opportunities      Opportunity[]
  activities         Activity[]   @relation("AccountActivities")
  tasks              Task[]       @relation("AccountTasks")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Contact {
  id               String    @id @default(uuid())
  fullName         String
  jobTitle         String?
  email            String?
  phone            String?
  preferredChannel String?
  status           String    @default("ACTIVE")
  ownerId          String
  owner            User      @relation("ContactOwner", fields: [ownerId], references: [id])
  accountId        String?
  account          Account?  @relation(fields: [accountId], references: [id])
  opportunities    Opportunity[]
  activities       Activity[] @relation("ContactActivities")
  tasks            Task[]     @relation("ContactTasks")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Opportunity {
  id                String           @id @default(uuid())
  opportunityName   String
  stage             OpportunityStage @default(PROSPECTING)
  estimatedValue    Int?
  probability       Int?
  expectedCloseDate DateTime?
  lostReason        String?
  wonDate           DateTime?
  closedDate        DateTime?
  ownerId           String
  owner             User             @relation("OpportunityOwner", fields: [ownerId], references: [id])
  accountId         String
  account           Account          @relation(fields: [accountId], references: [id])
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id])
  activities        Activity[]       @relation("OpportunityActivities")
  tasks             Task[]           @relation("OpportunityTasks")
  stageHistory      OpportunityStageHistory[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model OpportunityStageHistory {
  id            String           @id @default(uuid())
  opportunityId String
  opportunity   Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage     OpportunityStage?
  toStage       OpportunityStage
  actorUserId   String?
  actorUser     User?            @relation("OpportunityStageActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  note          String?
  createdAt     DateTime         @default(now())

  @@index([opportunityId, createdAt])
  @@index([actorUserId, createdAt])
}

model Activity {
  id            String       @id @default(uuid())
  type          ActivityType
  subject       String
  description   String?
  occurredAt    DateTime
  ownerId       String
  owner         User         @relation("ActivityOwner", fields: [ownerId], references: [id])
  leadId        String?
  lead          Lead?        @relation("LeadActivities", fields: [leadId], references: [id], onDelete: SetNull)
  accountId     String?
  account       Account?     @relation("AccountActivities", fields: [accountId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?     @relation("ContactActivities", fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation("OpportunityActivities", fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([ownerId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([contactId, occurredAt])
  @@index([opportunityId, occurredAt])
}

model Task {
  id            String     @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus @default(TODO)
  dueDate       DateTime?
  completedAt   DateTime?
  ownerId       String
  owner         User       @relation("TaskOwner", fields: [ownerId], references: [id])
  leadId        String?
  lead          Lead?        @relation("LeadTasks", fields: [leadId], references: [id], onDelete: SetNull)
  accountId     String?
  account       Account?     @relation("AccountTasks", fields: [accountId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?     @relation("ContactTasks", fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation("OpportunityTasks", fields: [opportunityId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([ownerId, status, dueDate])
  @@index([leadId, dueDate])
  @@index([accountId, dueDate])
  @@index([contactId, dueDate])
  @@index([opportunityId, dueDate])
}

model Note {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  body       String
  isInternal Boolean  @default(true)
  authorUserId String?
  authorUser   User? @relation("NoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  comments   NoteComment[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId, createdAt])
  @@index([authorUserId, createdAt])
}

model NoteComment {
  id          String   @id @default(uuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      NoteComment? @relation("NoteCommentParent", fields: [parentId], references: [id], onDelete: Cascade)
  replies     NoteComment[] @relation("NoteCommentParent")
  body        String
  authorUserId String?
  authorUser   User? @relation("NoteCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([noteId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorUserId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, revokedAt])
}
