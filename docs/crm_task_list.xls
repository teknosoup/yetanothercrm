        <Cell><Data ss:Type="String">Data Enrichment (Company/Person)</Data></Cell>
        <Cell><Data ss:Type="String">P6-S1</Data></Cell>
        <Cell><Data ss:Type="String">Sebagai user, saya bisa menjalankan enrichment untuk lead/account/contact.</Data></Cell>
        <Cell><Data ss:Type="String">Plugin memanggil provider eksternal dan menulis hasil ke field whitelist atau sebagai suggestion. Hasil menyimpan sumber data dan timestamp.</Data></Cell>
        <Cell><Data ss:Type="String">C6-S2/C6-S3 (endpoint+secrets), C1 (opsional untuk custom fields)</Data></Cell>
        <Cell><Data ss:Type="String">Could Have</Data></Cell>
