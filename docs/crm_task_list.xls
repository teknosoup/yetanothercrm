        <Cell><Data ss:Type="String">P6-S2</Data></Cell>
        <Cell><Data ss:Type="String">Sebagai admin, saya bisa membatasi field mana yang boleh dioverwrite oleh enrichment.</Data></Cell>
        <Cell><Data ss:Type="String">Ada whitelist field yang boleh ditulis. Field lain hanya disimpan sebagai suggestion dan tidak mengubah record sampai disetujui user.</Data></Cell>
        <Cell><Data ss:Type="String">P6-S1</Data></Cell>
